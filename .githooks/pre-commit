#!/bin/sh
set -eu

if command -v mise >/dev/null 2>&1; then
  exec mise exec -- cargo run --quiet --bin validate-records
fi

if command -v cargo >/dev/null 2>&1; then
  exec cargo run --quiet --bin validate-records
fi

echo "mise or cargo is required to validate Lore records. Run: mise install" >&2
exit 1
